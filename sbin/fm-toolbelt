#!/usr/bin/env bash
# fm-toolbelt - list every executable sbin/ script with its header description.
# Usage: fm-toolbelt
#   Prints "<name><TAB><description>" for each executable regular file in
#   sbin/, one per line, sorted by name. The description is the first header
#   comment line after the shebang (shebang and "# shellcheck" directive
#   lines are skipped, and a leading "<name> - " prefix is stripped). Scripts
#   with no such comment print "(no header)" instead of failing.
#   This replaces the hand-maintained toolbelt table in README.md so the
#   listing can never drift from the actual scripts on disk.
set -euo pipefail

SBIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

describe() {
  local file="$1" name desc="" line_num=0 line
  name="$(basename "$file")"
  while IFS= read -r line || [ -n "$line" ]; do
    line_num=$((line_num + 1))
    if [ "$line_num" -eq 1 ] && [[ "$line" == "#!"* ]]; then
      continue
    fi
    if [ -z "$line" ]; then
      continue
    fi
    if [[ "$line" == "# shellcheck"* ]]; then
      continue
    fi
    if [[ "$line" == "#"* ]]; then
      desc="${line#\#}"
      desc="${desc# }"
    elif [[ "$line" == "//"* ]]; then
      desc="${line#//}"
      desc="${desc# }"
    fi
    break
  done <"$file"
  desc="${desc#"$name" - }"
  desc="${desc#"$name" -}"
  [ -n "$desc" ] || desc="(no header)"
  printf '%s\t%s\n' "$name" "$desc"
}

for f in "$SBIN_DIR"/*; do
  [ -f "$f" ] && [ -x "$f" ] || continue
  describe "$f"
done | sort
