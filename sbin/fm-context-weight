#!/usr/bin/env bun
// fm-context-weight - estimate the token weight of shared and home-specific
// context using the repository's byte-stable chars/4 tokenizer.
//
// `--budget` switches to a ratchet: it exits non-zero when the tracked
// template layer exceeds the committed ceilings in context-budget.toml.

import { existsSync, readFileSync, readdirSync } from "node:fs";
import { dirname, join, relative, resolve } from "node:path";
import { fileURLToPath } from "node:url";

import { countTokens, tokenizerBackend } from "../benchmarks/tokenizer.ts";

type ContextFile = {
	label: string;
	text: string;
	tokens: number;
};

type ContextSection = {
	file: string;
	section: string;
	tokens: number;
};

type Mate = {
	id: string;
	home: string;
};

type MateRow = {
	mate: string;
	skill: string;
	tokens: number;
	source: string;
};

function configuredPath(value: string | undefined): string | undefined {
	const trimmed = value?.trim();
	return trimmed ? resolve(trimmed) : undefined;
}

function contextRoots(): { codeRoot: string; dataRoot: string } {
	const scriptRoot = resolve(dirname(fileURLToPath(import.meta.url)), "..");
	const configuredHome = configuredPath(process.env.FM_HOME);
	const legacyRoot = configuredPath(process.env.FM_ROOT_OVERRIDE);
	const codeRoot = configuredPath(process.env.FM_CODE_ROOT_OVERRIDE)
		?? (!configuredHome && legacyRoot ? legacyRoot : scriptRoot);
	const home = configuredHome ?? legacyRoot ?? codeRoot;
	const dataRoot = configuredPath(process.env.FM_DATA_OVERRIDE) ?? join(home, "data");
	return { codeRoot, dataRoot };
}

function markdownSections(file: ContextFile): ContextSection[] {
	const headings = [...file.text.matchAll(/^#{1,6}[ \t]+(.+?)[ \t]*\r?$/gm)];
	if (headings.length === 0) {
		return [{ file: file.label, section: "(whole file)", tokens: countTokens(file.text) }];
	}

	const sections: ContextSection[] = [];
	const firstHeading = headings[0];
	if ((firstHeading.index ?? 0) > 0) {
		sections.push({
			file: file.label,
			section: "(preamble)",
			tokens: countTokens(file.text.slice(0, firstHeading.index)),
		});
	}
	for (const [index, heading] of headings.entries()) {
		const start = heading.index ?? 0;
		const end = headings[index + 1]?.index ?? file.text.length;
		sections.push({
			file: file.label,
			section: heading[1].replace(/\t/g, " "),
			tokens: countTokens(file.text.slice(start, end)),
		});
	}
	return sections;
}

function compareWeight(
	a: { tokens: number; label?: string; file?: string; section?: string },
	b: { tokens: number; label?: string; file?: string; section?: string },
): number {
	return b.tokens - a.tokens
		|| (a.label ?? a.file ?? "").localeCompare(b.label ?? b.file ?? "")
		|| (a.section ?? "").localeCompare(b.section ?? "");
}

// Parse "- <id> - ... (home: <path>; ...)" registry lines from
// data/secondmates.md - the same shape fm identity-migrate and friends
// parse in shell. Malformed or unreadable input degrades to no mates found.
function parseSecondmates(dataRoot: string): Mate[] {
	const path = join(dataRoot, "secondmates.md");
	if (!existsSync(path)) return [];
	let text: string;
	try {
		text = readFileSync(path, "utf8");
	} catch {
		return [];
	}
	const mates: Mate[] = [];
	for (const match of text.matchAll(/^- (\S+) - [^(]*\(home: ([^;)]+)[;)]/gm)) {
		mates.push({ id: match[1], home: resolve(match[2].trim()) });
	}
	return mates;
}

// Extract skills.enabled + skills.includeSkills from a mate's config/omp.yml.
// Narrow indentation reader for the home-skills reconciler shape:
//   skills:
//     enabled: true|false
//     includeSkills:
//       - name-one
function extractSkillsConfig(yamlText: string): { enabled: boolean | null; includeSkills: string[] } {
	const lines = yamlText.split(/\r?\n/);
	const names: string[] = [];
	let inSkills = false;
	let skillsIndent = 0;
	let inInclude = false;
	let includeIndent = 0;
	let enabled: boolean | null = null;

	for (const raw of lines) {
		if (raw.trim() === "") continue;
		const indent = raw.length - raw.trimStart().length;
		const trimmed = raw.trim();

		if (!inSkills) {
			if (indent === 0 && /^skills:\s*$/.test(trimmed)) {
				inSkills = true;
				skillsIndent = indent;
			}
			continue;
		}
		if (indent <= skillsIndent) break;

		if (!inInclude) {
			const enabledMatch = /^enabled:\s*(true|false)\s*$/.exec(trimmed);
			if (enabledMatch) {
				enabled = enabledMatch[1] === "true";
				continue;
			}
			if (/^includeSkills:\s*$/.test(trimmed)) {
				inInclude = true;
				includeIndent = indent;
			}
			continue;
		}
		if (indent <= includeIndent) break;

		const item = trimmed.match(/^-\s*(.+)$/);
		if (!item) continue;
		const name = item[1].trim().replace(/^["'](.*)["']$/, "$1");
		if (name) names.push(name);
	}
	return { enabled, includeSkills: names };
}

// Resolve one included skill against the isolated home skill surfaces:
// <home>/.omp/skills/<name>, then a real local extension package under
// <home>/.omp/extensions/*/skills/<name>. Cache and whole-catalog .agents
// paths are intentionally not weighed for specialist homes.
function resolveSkillFile(home: string, name: string): { path: string; source: string } | undefined {
	const native = join(home, ".omp", "skills", name, "SKILL.md");
	if (existsSync(native)) return { path: native, source: "home/.omp/skills" };

	const extRoot = join(home, ".omp", "extensions");
	if (!existsSync(extRoot)) return undefined;
	try {
		for (const entry of readdirSync(extRoot, { withFileTypes: true })) {
			if (!entry.isDirectory() || entry.name.startsWith(".")) continue;
			const skillMd = join(extRoot, entry.name, "skills", name, "SKILL.md");
			if (existsSync(skillMd)) return { path: skillMd, source: "home/.omp/extensions" };
		}
	} catch {
		return undefined;
	}
	return undefined;
}

function compareMateRow(a: MateRow, b: MateRow): number {
	return b.tokens - a.tokens || a.skill.localeCompare(b.skill);
}

// Per-mate always-on weight: for each home registered in data/secondmates.md,
// the token weight of every skill its config/omp.yml includeSkills names,
// plus a per-mate total. Missing config, an empty include list, or an
// unresolvable skill name all degrade to a labeled zero-token row rather than
// throwing - this reporter never fails a run over one mate's incomplete setup.
function collectMateWeights(dataRoot: string): MateRow[] {
	const mates = parseSecondmates(dataRoot);
	const rows: MateRow[] = [];

	for (const mate of mates) {
		const configPath = join(mate.home, "config", "omp.yml");
		if (!existsSync(configPath)) {
			rows.push({ mate: mate.id, skill: "(no config/omp.yml)", tokens: 0, source: "-" });
			continue;
		}

		let skillsConfig: { enabled: boolean | null; includeSkills: string[] };
		try {
			skillsConfig = extractSkillsConfig(readFileSync(configPath, "utf8"));
		} catch {
			rows.push({ mate: mate.id, skill: "(unreadable config/omp.yml)", tokens: 0, source: "-" });
			continue;
		}
		if (skillsConfig.enabled === false || skillsConfig.includeSkills.length === 0) {
			rows.push({ mate: mate.id, skill: "(empty effective skill set)", tokens: 0, source: "-" });
			continue;
		}

		const skillRows: MateRow[] = [];
		let total = 0;
		for (const name of skillsConfig.includeSkills) {
			const resolved = resolveSkillFile(mate.home, name);
			if (!resolved) {
				skillRows.push({ mate: mate.id, skill: name, tokens: 0, source: "unresolved" });
				continue;
			}
			try {
				const tokens = countTokens(readFileSync(resolved.path, "utf8"));
				total += tokens;
				skillRows.push({ mate: mate.id, skill: name, tokens, source: resolved.source });
			} catch {
				skillRows.push({ mate: mate.id, skill: name, tokens: 0, source: "unreadable" });
			}
		}
		skillRows.sort(compareMateRow);
		rows.push(...skillRows);
		rows.push({ mate: mate.id, skill: "TOTAL", tokens: total, source: "-" });
	}
	return rows;
}

function addFile(files: ContextFile[], seen: Set<string>, path: string, label: string): void {
	if (!existsSync(path)) return;
	const absolute = resolve(path);
	if (seen.has(absolute)) return;
	const text = readFileSync(absolute, "utf8");
	files.push({ label, text, tokens: countTokens(text) });
	seen.add(absolute);
}

function collectContext(): ContextFile[] {
	const { codeRoot, dataRoot } = contextRoots();
	const files: ContextFile[] = [];
	const seen = new Set<string>();

	const agentsPath = join(codeRoot, "AGENTS.md");
	if (!existsSync(agentsPath)) {
		throw new Error(`required context file not found: ${agentsPath}`);
	}
	addFile(files, seen, agentsPath, "AGENTS.md");

	const skillsRoot = join(codeRoot, ".agents", "skills");
	if (existsSync(skillsRoot)) {
		for (const entry of readdirSync(skillsRoot, { withFileTypes: true })) {
			if (!entry.isDirectory()) continue;
			const skillPath = join(skillsRoot, entry.name, "SKILL.md");
			addFile(files, seen, skillPath, relative(codeRoot, skillPath));
		}
	}

	addFile(files, seen, join(dataRoot, "cap.md"), "data/cap.md");
	addFile(files, seen, join(dataRoot, "charter.md"), "data/charter.md");
	const matesRoot = join(dataRoot, "mates");
	if (existsSync(matesRoot)) {
		for (const entry of readdirSync(matesRoot, { withFileTypes: true })) {
			if (!entry.isDirectory()) continue;
			const briefPath = join(matesRoot, entry.name, "brief.md");
			if (!existsSync(briefPath)) continue;
			const text = readFileSync(briefPath, "utf8");
			if (!/^You are a secondmate:/m.test(text)) continue;
			addFile(files, seen, briefPath, `data/mates/${entry.name}/brief.md`);
		}
	}

	return files.sort(compareWeight);
}

function readCeiling(tomlText: string, key: string): number | null {
	const match = new RegExp(`^${key}\\s*=\\s*(\\d+)`, "m").exec(tomlText);
	return match ? Number(match[1]) : null;
}

// `--budget`: the compiled form of the "fight context accretion" rule. The
// tracked template layer - AGENTS.md (always-on) plus the lazy skills - may
// only stay flat or shrink against the committed ceilings in
// context-budget.toml. Local-layer files (cap.md, charter.md, briefs) are
// excluded on purpose: they vary per machine and fleet and never travel.
// Over budget exits 1 (a prose addition must be paid for with a cut or a
// reviewed ceiling raise); slack exits 0 but nudges to tighten the ceiling so
// a reduction is locked in. This is a one-way ratchet, not a static cap.
function budgetCheck(files: ContextFile[], codeRoot: string): number {
	const budgetPath = process.env.FM_CONTEXT_BUDGET_FILE ?? join(codeRoot, "context-budget.toml");
	if (!existsSync(budgetPath)) {
		console.error(`context budget: no budget file at ${budgetPath}`);
		return 1;
	}
	const toml = readFileSync(budgetPath, "utf8");
	const alwaysOnMax = readCeiling(toml, "always_on_max");
	const governanceMax = readCeiling(toml, "governance_max");
	if (alwaysOnMax === null || governanceMax === null) {
		console.error(`context budget: ${budgetPath} must set always_on_max and governance_max`);
		return 1;
	}

	const alwaysOn = files.find((file) => file.label === "AGENTS.md")?.tokens ?? 0;
	const governance = files
		.filter((file) => file.label === "AGENTS.md" || file.label.startsWith(".agents/skills/"))
		.reduce((sum, file) => sum + file.tokens, 0);

	let status = 0;
	let slack = false;
	const check = (name: string, current: number, max: number): void => {
		const head = `${name.padEnd(11)} ${String(current).padStart(6)} tokens`;
		if (current > max) {
			console.log(`FAIL  ${head}  > ceiling ${String(max).padStart(6)}  (+${current - max} over budget)`);
			status = 1;
		} else if (current < max) {
			console.log(`ok    ${head}  < ceiling ${String(max).padStart(6)}  (ratchet: lower to ${current})`);
			slack = true;
		} else {
			console.log(`ok    ${head}  = ceiling ${String(max).padStart(6)}`);
		}
	};
	check("always_on", alwaysOn, alwaysOnMax);
	check("governance", governance, governanceMax);

	if (status === 1) {
		console.error("context budget exceeded: pay for the addition with a cut, or justify a ceiling raise in review.");
	} else if (slack) {
		console.error(`context budget has slack: tighten a ceiling in ${relative(codeRoot, budgetPath) || budgetPath} to lock in the reduction.`);
	}
	return status;
}

function main(): void {
	const { dataRoot } = contextRoots();
	const files = collectContext();
	const sections = files.flatMap(markdownSections).sort(compareWeight);
	const total = files.reduce((sum, file) => sum + file.tokens, 0);
	const mateRows = collectMateWeights(dataRoot);

	console.log(`estimated_total_tokens\t${total}`);
	console.log(`tokenizer\t${tokenizerBackend}`);
	console.log("");
	console.log("files");
	console.log("tokens\tfile");
	for (const file of files) console.log(`${file.tokens}\t${file.label}`);
	console.log("");
	console.log("sections");
	console.log("tokens\tfile\tsection");
	for (const section of sections) {
		console.log(`${section.tokens}\t${section.file}\t${section.section}`);
	}
	console.log("");
	console.log("per-mate");
	console.log("mate\tskill\ttokens\tsource");
	for (const row of mateRows) {
		console.log(`${row.mate}\t${row.skill}\t${row.tokens}\t${row.source}`);
	}
}

try {
	if (process.argv.slice(2).includes("--budget")) {
		const { codeRoot } = contextRoots();
		process.exit(budgetCheck(collectContext(), codeRoot));
	}
	main();
} catch (error) {
	console.error(`error: ${error instanceof Error ? error.message : String(error)}`);
	process.exit(1);
}
