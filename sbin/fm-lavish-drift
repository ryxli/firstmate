#!/usr/bin/env bun
'use strict';

// lavish-drift: fleet convergence checker for lavish-axi
// Answers: which lavish is each surface actually running, and do they all
// converge on the canonical build?
// Exit 0 = CONVERGED (or WARN-only), Exit 1 = DRIFT (any FAIL).

const { execSync } = require('child_process');
const { createHash } = require('crypto');
const fs = require('fs');
const path = require('path');
const os = require('os');

const HOME = os.homedir();
const CANONICAL_DIR = path.join(HOME, 'code/harness/lavish-axi');
const CANONICAL_CLI = path.join(CANONICAL_DIR, 'dist/cli.mjs');

// --- helpers ---

function sha256file(filePath) {
  try {
    return createHash('sha256').update(fs.readFileSync(filePath)).digest('hex').slice(0, 12);
  } catch {
    return null;
  }
}

function abbrev(p) {
  if (!p) return '(none)';
  return p.replace(HOME, '~');
}

function run(cmd) {
  try {
    return execSync(cmd, { encoding: 'utf8', stdio: ['pipe', 'pipe', 'pipe'] }).trim();
  } catch {
    return '';
  }
}

function nearestVersion(filePath) {
  let dir = path.dirname(filePath);
  for (let i = 0; i < 10; i++) {
    const pkgFile = path.join(dir, 'package.json');
    if (fs.existsSync(pkgFile)) {
      try {
        return JSON.parse(fs.readFileSync(pkgFile, 'utf8')).version || '?';
      } catch { return '?'; }
    }
    const up = path.dirname(dir);
    if (up === dir) break;
    dir = up;
  }
  return '?';
}

function classifyPath(p) {
  if (!p) return 'other';
  if (p.startsWith(CANONICAL_DIR)) return 'canonical-fork';
  if (p.includes('/.npm/_npx/')) return 'npx-cache';
  if (p.includes('/.bun/')) return 'bun-global';
  return 'other';
}

function realPath(p) {
  try { return fs.realpathSync(p); } catch { return p; }
}

function renderTable(headers, rows) {
  const widths = headers.map((h, i) =>
    Math.max(h.length, ...rows.map(r => String(r[i] ?? '').length))
  );
  const fmtRow = (row) =>
    row.map((cell, i) => String(cell ?? '').padEnd(widths[i])).join(' | ');
  const sep = widths.map(w => '-'.repeat(w)).join('-+-');
  return [fmtRow(headers), sep, ...rows.map(fmtRow)].join('\n');
}

// --- inspection ---

const rows = [];
const fails = [];
const warns = [];

// 1. CANONICAL: the reference build
let canonicalRev = null;
{
  const branch = run(`git -C "${CANONICAL_DIR}" rev-parse --abbrev-ref HEAD`);
  const sha = run(`git -C "${CANONICAL_DIR}" rev-parse --short HEAD`);
  const exists = fs.existsSync(CANONICAL_CLI);
  canonicalRev = exists ? sha256file(CANONICAL_CLI) : null;
  const version = exists ? nearestVersion(CANONICAL_CLI) : '?';
  const label = (branch && sha) ? `${branch}@${sha}` : '(no git)';
  rows.push([
    'CANONICAL',
    abbrev(CANONICAL_CLI),
    version,
    canonicalRev ?? 'N/A',
    `${label} OK`
  ]);
  if (!exists) fails.push('canonical dist/cli.mjs is missing');
}

// 2. GLOBAL BIN: which lavish-axi + symlink resolution
{
  const binPath = run('which lavish-axi');
  if (!binPath) {
    rows.push(['GLOBAL BIN', '(not found)', '?', 'N/A', 'FAIL']);
    fails.push('lavish-axi not found on PATH');
  } else {
    const resolved = realPath(binPath);
    const rev = sha256file(resolved);
    const version = nearestVersion(resolved);
    const ok = canonicalRev !== null && rev === canonicalRev;
    if (!ok) fails.push(`global bin rev ${rev} != canonical ${canonicalRev}`);
    rows.push([
      'GLOBAL BIN',
      abbrev(resolved),
      version,
      rev ?? 'N/A',
      ok ? 'OK' : 'FAIL'
    ]);
  }
}

// 3. RUNNING SERVERS: node processes running any cli.mjs
{
  const pgrepOut = run('pgrep -fl cli.mjs');
  const pidCli = new Map(); // pid -> resolved cli path

  if (pgrepOut) {
    for (const line of pgrepOut.split('\n').filter(Boolean)) {
      const m = line.match(/^(\d+)\s+(.+)/);
      if (!m) continue;
      const [, pid, cmdline] = m;
      // extract the first absolute path ending in cli.mjs
      const pathM = cmdline.match(/(?:^|\s)(\/\S+cli\.mjs)/);
      if (pathM) pidCli.set(pid, pathM[1]);
    }
  }

  // build pid -> port[] from lsof LISTEN sockets
  const lsofOut = run('lsof -nP -iTCP -sTCP:LISTEN');
  const pidPorts = new Map();
  for (const line of lsofOut.split('\n').filter(Boolean)) {
    const parts = line.trim().split(/\s+/);
    // only node processes; last two parts are "addr:port" and "(LISTEN)"
    if (parts[0] !== 'node') continue;
    const pid = parts[1];
    const addrPort = parts[parts.length - 2];
    const portM = addrPort.match(/:(\d+)$/);
    if (!portM) continue;
    if (!pidPorts.has(pid)) pidPorts.set(pid, []);
    pidPorts.get(pid).push(portM[1]);
  }

  if (pidCli.size === 0) {
    rows.push(['SERVER', '(none running)', '-', '-', 'N/A']);
  } else {
    for (const [pid, cliPath] of pidCli) {
      const resolved = realPath(cliPath);
      const ports = pidPorts.get(pid) || [];
      const portStr = ports.join(',') || '?';
      const rev = sha256file(resolved);
      const version = nearestVersion(resolved);
      const cls = classifyPath(resolved);
      const ok = canonicalRev !== null && rev === canonicalRev;
      if (!ok) fails.push(`server PID ${pid} port ${portStr} rev ${rev} != canonical ${canonicalRev}`);
      rows.push([
        `SERVER:${portStr}`,
        abbrev(resolved),
        version,
        rev ?? 'N/A',
        `PID:${pid} ${cls} ${ok ? 'OK' : 'FAIL'}`
      ]);
    }
  }
}

// 4. NPX CACHE: latent drift source
{
  const npxBase = path.join(HOME, '.npm/_npx');
  let any = false;
  try {
    for (const entry of fs.readdirSync(npxBase)) {
      const lavishDir = path.join(npxBase, entry, 'node_modules', 'lavish-axi');
      if (fs.existsSync(lavishDir)) {
        any = true;
        const cliPath = path.join(lavishDir, 'dist', 'cli.mjs');
        const rev = sha256file(cliPath);
        const version = nearestVersion(cliPath);
        rows.push(['NPX CACHE', abbrev(lavishDir), version, rev ?? 'N/A', 'WARN']);
        warns.push(`npx cache present: ${abbrev(lavishDir)}`);
      }
    }
  } catch { /* no npx dir - fine */ }
  if (!any) {
    rows.push(['NPX CACHE', '(none)', '-', '-', 'OK']);
  }
}

// --- output ---
const HEADERS = ['surface', 'path', 'version', 'code-rev', 'verdict'];
console.log(renderTable(HEADERS, rows));
console.log('');

if (fails.length > 0) {
  console.log('DRIFT: ' + fails.join('; '));
  process.exit(1);
} else if (warns.length > 0) {
  console.log('CONVERGED (warns: ' + warns.join('; ') + ')');
} else {
  console.log('CONVERGED');
}
