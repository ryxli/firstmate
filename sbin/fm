#!/usr/bin/env -S BUN_RUNTIME_TRANSPILER_CACHE_PATH=0 bun
// fm - canonical TOON-native agent CLI entry point.
//
// Dispatches to verb modules auto-discovered via lib/verb-registry.ts.
// Each verb module is one file exporting a default { name, describe, run(argv) }.
// Adding a verb requires adding exactly one file: there is no separate registry.
//
// Root `fm --help` is the Cap-facing workflow guide (help.ts), not a verb dump.
// Bare `fm <verb> --help|-h` is intercepted here and rendered from passive HelpSpec
// before run() - help never invokes operational verb code.
// Full inventory: `fm toolbelt`. Nested detail: `fm fleet|home|tasks --help`.
// `help` is accepted as a synonym for `--help`.

import { fileURLToPath } from "node:url";
import { didYouMean, output, validationError } from "../.omp/extensions/cli/common";
import { commandHelp, emitTopLevelVerbHelp } from "../.omp/extensions/cli/help";
import { activeHome, forbiddenInSecondmate, isSecondmateHome } from "../.omp/extensions/cli/lib/role-contract";
import { loadVerbs } from "../.omp/extensions/cli/lib/verb-registry";

async function main(): Promise<number> {
	const argv = process.argv.slice(2);
	const home = activeHome(fileURLToPath(new URL("..", import.meta.url)).replace(/\/$/, ""));
	const secondmate = isSecondmateHome(home);
	if (secondmate) {
		process.env.FM_HOME = home;
		delete process.env.FM_ROOT_OVERRIDE;
		delete process.env.FM_STATE_OVERRIDE;
		delete process.env.FM_DATA_OVERRIDE;
		delete process.env.FM_PROJECTS_OVERRIDE;
		delete process.env.FM_CONFIG_OVERRIDE;
	}
	if (!argv.length || argv[0] === "--help" || argv[0] === "-h" || argv[0] === "help") {
		output(commandHelp("fm"));
		return 0;
	}
	const forbidden = secondmate ? forbiddenInSecondmate(argv) : null;
	if (forbidden) {
		output({
			error: `WRONG_ROLE: ${forbidden} is only available from the main firstmate home`,
			code: "WRONG_ROLE",
			role: "secondmate",
			home,
			help: ["Run this command from the main firstmate home, or use local fleet/task/status commands here."],
		});
		return 1;
	}

	const verbs = await loadVerbs();
	const verb = verbs.find(candidate => candidate.name === argv[0]);
	if (!verb) {
		const suggestions = didYouMean(verbs.map(candidate => candidate.name), argv[0]);
		return validationError(`Unknown command: ${argv[0]}`, suggestions.length > 0 ? [`Did you mean: ${suggestions.join(", ")}?`] : ["Run `fm --help` for available commands."]);
	}
	if (argv.length === 2 && (argv[1] === "--help" || argv[1] === "-h")) {
		return emitTopLevelVerbHelp(verb);
	}
	return await verb.run(argv);
}

process.exit(await main());
